# API Key for your LLM provider (OpenAI-compatible)
OPENCODE_GO_API_KEY=sk-your-api-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Base URL (default: OpenCode Go)
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Model override (default: deepseek-v4-flash)
# BRAIN_MODEL=gpt-4o
# BRAIN_SYNTHESIS_MODEL=gpt-4o
